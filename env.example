# LeadFinder Environment Configuration
# Copy this file to .env and fill in your values

# API Keys
SERPAPI_KEY=your_serpapi_key_here

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=120

# Database Configuration
DB_PATH=leads.db

# File System Configuration
EXPORT_FOLDER=/mnt/seagate/leads_downloads
SCIHUB_FOLDER=scihub_pdfs

# Flask Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5050
FLASK_DEBUG=False
FLASK_SECRET_KEY=your-secret-key-change-this

# Search Configuration
DEFAULT_RESEARCH_QUESTION=epigenetik och pre-diabetes
MAX_TEXT_LENGTH=4000
REQUEST_TIMEOUT=15

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=

# Performance Configuration
GUNICORN_WORKERS=4
REQUEST_POOL_SIZE=10

# Future Integrations (optional)
PUBMED_API_KEY=
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=

# =============================================================================
# RESEARCH FUNDING API KEYS
# =============================================================================

# SweCRIS API (Swedish Research Information System)
SWECRIS_API_KEY=your_swecris_api_key_here
SWECRIS_BASE_URL=https://api.swecris.se/v1
SWECRIS_ENABLED=True

# CORDIS API (EU Research Projects)
CORDIS_API_KEY=your_cordis_api_key_here
CORDIS_BASE_URL=https://cordis.europa.eu/api
CORDIS_ENABLED=True

# NIH RePORTER API (US Research Projects)
NIH_API_KEY=your_nih_api_key_here
NIH_BASE_URL=https://api.reporter.nih.gov/v2
NIH_ENABLED=True

# NSF API (US National Science Foundation)
NSF_API_KEY=your_nsf_api_key_here
NSF_BASE_URL=https://api.nsf.gov/v1
NSF_ENABLED=True

# Research search configuration
RESEARCH_MAX_RESULTS=50
RESEARCH_TIMEOUT=30 